NODE_ENV=development
PORT=4000

# Local pnpm dev with `docker compose up redis` (Redis published on localhost):
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=jetpaas-dev

# Browser origin allowed to call the API (must match where the web app runs):
CORS_ORIGIN=http://localhost:3000

# Docker full stack (`docker compose up --build`) sets REDIS_HOST=redis automatically.

# Web app origin for CORS (Vite dev server and docker-compose web service use port 3000)
CORS_ORIGIN=http://localhost:3000
